---
import "../styles/global.css";
interface Props {
  title?: string;
  description?: string;
}
const { title = "Yifan Chen · 陈奕帆", description = "Personal website of Yifan Chen — Researcher in Safe & Trustworthy AI, Autonomous Driving and Machine Learning for Transportation." } = Astro.props;
const faviconHref = `${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/+/g, "/");
---
<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05070e" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script is:inline>
      (function () {
        const saved = localStorage.getItem("lang");
        const initial = saved || (navigator.language?.toLowerCase().startsWith("zh") ? "zh" : "en");
        document.documentElement.setAttribute("data-lang", initial);
        document.documentElement.setAttribute("lang", initial === "zh" ? "zh-CN" : "en");
      })();

      window.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll("[data-lang-toggle]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const cur = document.documentElement.getAttribute("data-lang") || "en";
            const next = cur === "en" ? "zh" : "en";
            document.documentElement.setAttribute("data-lang", next);
            document.documentElement.setAttribute("lang", next === "zh" ? "zh-CN" : "en");
            localStorage.setItem("lang", next);
          });
        });

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      });
    </script>
  </body>
</html>
